# ── Deployment ──
DEPLOYMENT_MODE=local

# ── Datenbank ──
DB_PASSWORD=nkcheck_dev_secret
POSTGRES_USER=nkcheck
POSTGRES_DB=nkcheck
POSTGRES_PORT=5432

# ── LLM Provider ──
# vllm (GPU, empfohlen) oder ollama (CPU)
LLM_PROVIDER=vllm
LLM_HOST=http://vllm:8000
LLM_MODEL=qwen2.5:32b
LLM_MODEL_PATH=Qwen/Qwen2.5-32B-Instruct-AWQ

# Fallback-Modell (Vertragsanalyse, Reasoning)
LLM_FALLBACK_MODEL=mixtral:8x7b

# Chunker-Support-Modell (OCR/Section-Detection)
LLM_CHUNKER_MODEL=qwen2.5:14b

# ── vLLM ──
VLLM_MAX_MODEL_LEN=32768
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_PORT=8000

# ── Chunker ──
CHUNKER_PORT=5000
CHUNKER_UPLOAD_FOLDER=/data/uploads
CHUNKER_OUTPUT_FOLDER=/data/output
RQ_TIMEOUT=480

# ── Weft ──
RESTATE_PORT=8080
RESTATE_ADMIN_PORT=9070
WEFT_ORCHESTRATOR_PORT=9080
WEFT_API_PORT=3000
WEFT_NODE_RUNNER_PORT=9082

# ── Frontends ──
DASHBOARD_PORT=5173
OPERATOR_UI_PORT=5174

# ── Shared Volumes ──
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
CHUNKS_DIR=./data/chunks
OUTPUT_DIR=./data/output

# ── Redis ──
REDIS_PORT=6379

# ── OpenRouter (optional, fur Cloud-Fallback) ──
# OPENROUTER_API_KEY=
